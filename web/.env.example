# =============================================================================
# XTAGE — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Variáveis com * são obrigatórias para o funcionamento básico.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE *
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# URL pública da aplicação (usada em callbacks de autenticação) *
NEXT_PUBLIC_SITE_URL=https://seudominio.com

# -----------------------------------------------------------------------------
# ASAAS — Gateway de Pagamentos *
# -----------------------------------------------------------------------------
# Chave da conta principal da plataforma (não a subconta do professor)
ASAAS_API_KEY=sua_asaas_api_key_aqui

# URL da API (omitir para usar sandbox; em produção use https://api.asaas.com/v3)
# ASAAS_API_URL=https://api.asaas.com/v3

# Segredo para validar webhooks recebidos do Asaas *
ASAAS_WEBHOOK_SECRET=seu_webhook_secret_aqui

# Ambiente: "sandbox" (padrão) ou "production"
NEXT_PUBLIC_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE NEGÓCIO
# -----------------------------------------------------------------------------
# Taxa de split da plataforma sobre cada venda (padrão: 10%)
PLATFORM_SPLIT_PERCENT=10

# Taxa de juros mensal para parcelamento no cartão (padrão: 2.99%)
CHECKOUT_INTEREST_RATE=0.0299

# -----------------------------------------------------------------------------
# PUSH NOTIFICATIONS (Web Push / VAPID)
# Gere com: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=sua_chave_publica_vapid
VAPID_PRIVATE_KEY=sua_chave_privada_vapid

# -----------------------------------------------------------------------------
# RESEND — Email Marketing (opcional)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_sua_api_key_resend

# IDs de audiência para segmentação na lista de espera
RESEND_AUDIENCE_ID=id_da_audiencia_geral
RESEND_AUDIENCE_ID_PROFESSORES=id_da_audiencia_professores
RESEND_AUDIENCE_ID_ALUNOS=id_da_audiencia_alunos

# -----------------------------------------------------------------------------
# META CONVERSIONS API — CAPI (opcional)
# -----------------------------------------------------------------------------
META_PIXEL_ID=seu_pixel_id
META_ACCESS_TOKEN=seu_access_token_meta

# -----------------------------------------------------------------------------
# UPSTASH REDIS — Rate Limiting distribuído (opcional)
# Se não configurado, usa armazenamento em memória (não recomendado em produção)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu_token_upstash

# -----------------------------------------------------------------------------
# SENTRY — Error Tracking (opcional)
# -----------------------------------------------------------------------------
SENTRY_ORG=sua_org_sentry
SENTRY_PROJECT=seu_projeto_sentry
SENTRY_AUTH_TOKEN=seu_auth_token_sentry

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Define "true" para bloquear novos cadastros (modo pré-lançamento)
PRE_LAUNCH=true

# Define "false" para desativar o bloqueio de sessão única (anti-pirataria)
# ENABLE_SESSION_LOCK=false
